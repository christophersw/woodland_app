# Optional: use Railway Postgres or another external DB
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# Comma-separated Chess.com usernames to ingest
CHESS_COM_USERNAMES=magnuscarlsen,alireza2003,anandviswanathan

# Max archive age to ingest in months. Use 0 for full history.
INGEST_MONTH_LIMIT=24

# Optional custom user agent for Chess.com API requests
CHESS_COM_USER_AGENT=woodland-chess/0.1 (+club analytics app)

# for SQL parsing LLM 
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional app authentication
AUTH_ENABLED=false
AUTH_BOOTSTRAP_ADMIN_EMAIL=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_SIGNING_KEY=